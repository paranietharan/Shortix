# Application Settings
APP_ENV=development
PORT=8080

# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/shortix?sslmode=disable

# Seeder Credentials (used by: go run database/cmd/main.go -seed)
SEED_ADMIN_EMAIL=admin@shortix.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_USER_EMAIL=user@shortix.com
SEED_USER_PASSWORD=User@12345

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# SMTP Email Configuration
# If SMTP_HOST or SMTP_FROM_EMAIL is empty, email sending is disabled (noop mode)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@shortix.local
SMTP_FROM_NAME=Shortix

# JWT Configuration
JWT_SECRET=1b54ca0bb8017a3a639ad20632bf2b8b99b71f63

# Token TTLs (in Go duration format: e.g., 15m, 24h, 10s)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
EMAIL_VERIFY_OTP_TTL=10m
PASSWORD_RESET_OTP_TTL=10m
PASSWORD_RESET_TEMP_TTL=15m

# Bcrypt Password Hashing
BCRYPT_COST=12

# Rate Limiting
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_FORGOT_PASSWORD_MAX=5